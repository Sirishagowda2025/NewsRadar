# ─────────────────────────────────────────────────────────────────────────────
# NewsRadar — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env, fill in your values, and load it before running:
#
#   cp .env.example .env
#   # edit .env with your values 
#   source .env        # Linux / macOS
#   # OR use python-dotenv (pip install python-dotenv) and call load_dotenv()
#
# .env is listed in .gitignore — it will NEVER be committed to Git.
# Only .env.example (this file) is committed — it contains no real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Email (SMTP) ─────────────────────────────────────────────────────────────

# Your sending email address
SENDER_EMAIL=you@example.com

# Gmail App Password (NOT your Gmail login password).
# Generate one at: https://myaccount.google.com/apppasswords
# Enable 2FA first, then create an App Password for "Mail".
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# SMTP server settings (defaults work for Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Comma-separated list of recipient email addresses
RECIPIENTS=recipient1@example.com,recipient2@example.com

# Optional CC recipients (leave blank if not needed)
CC_RECIPIENTS=

# Email subject line ({date} is replaced with today's date automatically)
EMAIL_SUBJECT=NewsRadar Intelligence — {date}

# ── AI (Ollama) ───────────────────────────────────────────────────────────────

# Which Ollama model to use. Pull it first: ollama pull qwen3:4b
OLLAMA_MODEL=qwen3:4b

# Articles scoring below this are dropped (0–10 scale).
# 7 = strict (only direct business impact). 5 = more articles.
MIN_RELEVANCE_SCORE=7

# Set to false to skip AI scoring entirely (faster, no Ollama needed)
AI_ENABLED=true
